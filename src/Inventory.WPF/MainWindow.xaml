<Window x:Class="Inventory.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Inventory System"
        Height="600"
        Width="1000"
        Background="#f5f7fa"
        WindowState="Maximized">

    <Grid Margin="10">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- PANEL IZQUIERDO -->
        <Border Background="White" CornerRadius="10" Padding="15" Margin="5">
            <StackPanel IsEnabled="{Binding IsFormEnabled}">

                <TextBlock Text="Crear Usuario"
                           FontSize="20"
                           FontWeight="Bold"
                           Margin="0,0,0,15"/>

                <!-- Nombre -->
                <TextBlock Text="Nombre"/>
                <TextBox Text="{Binding Name}" Height="30"/>

                <!-- Contacto -->
                <TextBlock Text="Contacto" Margin="0,10,0,0"/>
                <TextBox Text="{Binding Contact}" Height="30"/>

                <!-- Área -->
                <TextBlock Text="Área" Margin="0,10,0,0"/>
                <ComboBox ItemsSource="{Binding Areas}"
                          SelectedItem="{Binding SelectedArea}"
                          DisplayMemberPath="Name"
                          Height="30"/>

                <!-- Rol -->
                <TextBlock Text="Rol" Margin="0,10,0,0"/>
                <ComboBox ItemsSource="{Binding Roles}"
                          SelectedItem="{Binding SelectedRole}"
                          DisplayMemberPath="Name"
                          Height="30"/>

                <!-- Botón -->
                <Button Content="Guardar"
                        Command="{Binding CreateUserCommand}"
                        Background="#0d6efd"
                        Foreground="White"
                        Height="35"
                        Margin="0,15,0,0"
                        BorderThickness="0"
                        Cursor="Hand"/>

            </StackPanel>
        </Border>

        <!-- PANEL DERECHO -->
        <Border Grid.Column="1"
                Background="White"
                CornerRadius="10"
                Padding="10"
                Margin="5">

            <Grid>

                <!-- TABLA -->
                <DataGrid ItemsSource="{Binding Users}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      CanUserDeleteRows="False"
                      CanUserResizeRows="False"
                      CanUserSortColumns="True"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      HeadersVisibility="Column"
                      RowHeight="30"
                      GridLinesVisibility="None"
                      Background="White">

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="Nombre" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Contacto" Binding="{Binding Contact}" Width="*"/>
                        <DataGridTextColumn Header="Área" Binding="{Binding AreaName}" Width="*"/>
                        <DataGridTextColumn Header="Rol" Binding="{Binding RoleName}" Width="*"/>

                        <!-- BOTÓN EDITAR -->
                        <DataGridTemplateColumn Header="Acciones" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Editar"
                        Padding="5"
                        Background="#ffc107"
                        Cursor="Hand"
                        Command="{Binding DataContext.EditUserCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                        CommandParameter="{Binding}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                    </DataGrid.Columns>

                </DataGrid>

                <!-- LOADING SOLO TABLA -->
                <Grid Background="#80000000"
                      Visibility="{Binding LoadingVisibility}">

                    <Border Background="White"
                            Padding="20"
                            CornerRadius="10"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">

                        <StackPanel>
                            <ProgressBar Width="200"
                                         Height="20"
                                         IsIndeterminate="True"/>

                            <TextBlock Text="Procesando..."
                                       Margin="0,10,0,0"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                    </Border>

                </Grid>

            </Grid>

        </Border>

    </Grid>
</Window>