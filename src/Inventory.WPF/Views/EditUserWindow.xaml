<Window x:Class="Inventory.WPF.Views.EditUserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Editar Usuario"
        MinHeight="400"
        MinWidth="350"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="#f5f7fa"
        SizeToContent="Height">

    <Window.Resources>

        <!-- VALIDACIÓN -->
        <Style TargetType="TextBox">
            <Style.Triggers>
                <Trigger Property="Validation.HasError" Value="True">
                    <Setter Property="BorderBrush" Value="Red"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Border Background="White"
            CornerRadius="10"
            Padding="20"
            Margin="10">

        <Grid>

            <!-- FILAS -->
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- HEADER -->
                <RowDefinition Height="*"/>
                <!-- FORM -->
                <RowDefinition Height="Auto"/>
                <!-- FOOTER -->
            </Grid.RowDefinitions>

            <!-- ================= HEADER ================= -->
            <TextBlock Text="Editar Usuario"
                       FontSize="18"
                       FontWeight="Bold"
                       Margin="0,0,0,15"/>

            <!-- ================= FORM ================= -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto">

                <Grid Margin="0,0,5,0">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- CONTACTO -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock Text="Contacto"/>

                        <TextBox x:Name="txtContact"
                                 Height="30"
                                 Text="{Binding Contact,
                                 UpdateSourceTrigger=PropertyChanged,
                                 ValidatesOnDataErrors=True}"/>

                        <TextBlock Foreground="Red"
                                   FontSize="11"
                                   Text="{Binding (Validation.Errors)[0].ErrorContent,
                                   ElementName=txtContact}"/>
                    </StackPanel>

                    <!-- EMAIL -->
                    <StackPanel Grid.Row="1" Margin="0,0,0,10">
                        <TextBlock Text="Email"/>

                        <TextBox x:Name="txtEmail"
                                 Height="30"
                                 Text="{Binding Email,
                                 UpdateSourceTrigger=PropertyChanged,
                                 ValidatesOnDataErrors=True}"/>

                        <TextBlock Foreground="Red"
                                   FontSize="11"
                                   Text="{Binding (Validation.Errors)[0].ErrorContent,
                                   ElementName=txtEmail}"/>
                    </StackPanel>

                    <!-- AREA -->
                    <StackPanel Grid.Row="2" Margin="0,0,0,10">
                        <TextBlock Text="Área"/>

                        <ComboBox ItemsSource="{Binding Areas}"
                                  SelectedItem="{Binding SelectedArea}"
                                  DisplayMemberPath="Name"
                                  Height="30"/>
                    </StackPanel>

                    <!-- ROLE -->
                    <StackPanel Grid.Row="3" Margin="0,0,0,10">
                        <TextBlock Text="Rol"/>

                        <ComboBox ItemsSource="{Binding Roles}"
                                  SelectedItem="{Binding SelectedRole}"
                                  DisplayMemberPath="Name"
                                  Height="30"/>
                    </StackPanel>

                </Grid>

            </ScrollViewer>

            <!-- ================= FOOTER ================= -->
            <Grid Grid.Row="2" Margin="0,20,0,0">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- espacio -->
                <TextBlock Grid.Column="0"/>

                <!-- cancelar -->
                <Button Grid.Column="1"
                        Content="Cancelar"
                        Width="90"
                        Margin="0,0,10,0"
                        Click="Cancel_Click"/>

                <!-- guardar -->
                <Button Grid.Column="2"
                        Content="Guardar"
                        Width="90"
                        Background="#198754"
                        Foreground="White"
                        BorderThickness="0"
                        Command="{Binding SaveCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>

            </Grid>

        </Grid>

    </Border>
</Window>